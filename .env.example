# A2A Hub 环境配置模板
# 复制此文件为 .env 并修改相应的值
# cp .env.example .env

# ==================== 应用配置 ====================
APP_ENV=dev
DEBUG=true

# ==================== API 服务 ====================
API_HOST_PORT=1880
A2A_HUB_PUBLIC_BASE_URL=http://127.0.0.1:1880

# ==================== 数据库配置 ====================
POSTGRES_DB=a2a_hub
POSTGRES_USER=a2a_hub
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST_PORT=1881

# ==================== Redis 配置 ====================
REDIS_HOST_PORT=1882

# ==================== MQTT 配置 ====================
MQTT_HOST_PORT=1883
MQTT_PUBLIC_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_TENANT_PASSWORD_SECRET=CHANGE_ME_TENANT_MQTT_SECRET

# ==================== 安全配置 ====================
SECRET_KEY=CHANGE_ME_SECRET_KEY
SERVICE_ACCOUNT_ISSUER_SECRET=CHANGE_ME_ISSUER_SECRET
SERVICE_ACCOUNT_TOKEN_EXPIRE_MINUTES=1440

# ==================== 默认租户 ====================
DEFAULT_TENANT_ID=tenant_001
DEFAULT_TENANT_NAME=默认租户
