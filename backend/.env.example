# a2a-hub compose deployment example

# Host ports
API_HOST_PORT=1880
POSTGRES_HOST_PORT=1881
REDIS_HOST_PORT=1882
MQTT_HOST_PORT=1883

# Public URLs
A2A_HUB_PUBLIC_BASE_URL=http://127.0.0.1:1880
MQTT_PUBLIC_BROKER_URL=mqtt://127.0.0.1:1883

# Postgres
POSTGRES_DB=a2a_hub
POSTGRES_USER=a2a_hub
POSTGRES_PASSWORD=change-me

# Security
SECRET_KEY=change-me-in-production
SERVICE_ACCOUNT_ISSUER_SECRET=change-me-in-production
SERVICE_ACCOUNT_TOKEN_EXPIRE_MINUTES=1440

# Initial data
DEFAULT_TENANT_ID=tenant_001
DEFAULT_TENANT_NAME=default-tenant

# MQTT shared account
MQTT_SHARED_USERNAME=agentlink
MQTT_SHARED_PASSWORD=change-me

# App
APP_ENV=prod
DEBUG=false
DOCS_TEST_ENABLED=true
